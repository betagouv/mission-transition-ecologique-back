{
  "name": "@tee-backoffice/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run @tee-backoffice/cms:dev",
    "build": "nx run @tee-backoffice/cms:build",
    "start": "nx run @tee-backoffice/cms:start",
    "lint": "nx run-many -t lint",
    "lint:affected": "nx affected -t lint",
    "typecheck": "nx run @tee-backoffice/cms:typecheck",
    "e2e": "nx run @tee-backoffice/cms-e2e:e2e",
    "generate:importmap": "pnpm --filter @tee-backoffice/cms generate:importmap",
    "generate:types": "pnpm --filter @tee-backoffice/cms generate:types"
  },
  "private": true,
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/next": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@typescript-eslint/utils": "^8",
    "eslint": "~9.39.4",
    "eslint-plugin-import": "^2",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "nx": "22.5.4",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8",
    "next": "15.4.11"
  },
  "packageManager": "pnpm@10.6.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "less",
      "nx",
      "sharp"
    ],
    "overrides": {
      "next": "15.4.11"
    }
  }
}
